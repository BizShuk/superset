{
    "name": "superset",
    "displayName": "Superset",
    "description": "\u5373\u6642\u5100\u8868\u677f:\u5075\u6e2c VSCode \u7d42\u7aef\u6a5f\u4e8b\u4ef6(\u958b\u95dc\u3001\u5207\u63db\u3001\u547d\u4ee4\u57f7\u884c\u3001\u8f38\u51fa),\u5f59\u6574\u6210\u7d50\u69cb\u5316\u6aa2\u8996;\u4e26\u63d0\u4f9b Markdown `tree` \u5340\u584a\u8a9e\u6cd5\u9ad8\u4eae\u8207\u9810\u89bd\u6e32\u67d3\u3002",
    "version": "0.13.2",
    "publisher": "shuk",
    "repository": {
        "type": "git",
        "url": "https://github.com/BizShuk/superset"
    },
    "license": "Apache-2.0",
    "icon": "images/icon.png",
    "engines": {
        "vscode": "^1.93.0",
        "node": ">=20.0.0"
    },
    "categories": [
        "Other",
        "Programming Languages"
    ],
    "main": "./out/extension.js",
    "extensionDependencies": [
        "vscode.git-base"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "languages": [
            {
                "id": "tree",
                "aliases": [
                    "markdown tree",
                    "tree highlight"
                ]
            }
        ],
        "grammars": [
            {
                "language": "tree",
                "scopeName": "source.tree",
                "path": "./syntaxes/tree.tmLanguage.json"
            },
            {
                "scopeName": "markdown.tree.codeblock",
                "path": "./syntaxes/tree-markdown-injection.tmLanguage.json",
                "injectTo": [
                    "text.html.markdown"
                ],
                "embeddedLanguages": {
                    "meta.embedded.block.tree": "tree"
                }
            }
        ],
        "markdown.markdownItPlugins": true,
        "markdown.previewStyles": [
            "./styles/tree.css",
            "./styles/todo-preview.css"
        ],
        "commands": [
            {
                "command": "superset.resetCaches",
                "title": "Superset: Reset Caches",
                "icon": "$(debug-restart)"
            },
            {
                "command": "superset.reportViewVisible",
                "title": "Superset: Report View Visible",
                "icon": "$(eye)"

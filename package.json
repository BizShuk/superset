        "viewsContainers": {
            "activitybar": [
                {
                    "id": "superset",
                    "title": "SuperSet",
                    "icon": "images/icon.png"
                },
                {
                    "id": "superset-overall",
                    "title": "Overall",
                    "icon": "images/icon.png"
                }
            ]
        },
        "views": {
            "superset": [
                {
                    "id": "superset.terminals",
                    "name": "Terminals",
                    "contextualTitle": "SuperSet",
                    "visibility": "visible"
                },
                {
                    "id": "superset.mdns",
                    "name": "MDNS",
                    "contextualTitle": "SuperSet",
                    "visibility": "collapsed"
                },
                {
                    "id": "superset.topology",
                    "name": "Topology",
                    "contextualTitle": "SuperSet",
                    "visibility": "collapsed"
                },
                {
                    "id": "superset.todo",
                    "name": "TODO",
                    "contextualTitle": "SuperSet",
                    "visibility": "visible"
                }
            ],
            "superset-overall": [
                {
                    "id": "superset.projectsTodo",
                    "name": "Projects TODO",
                    "contextualTitle": "Overall",
                    "visibility": "visible"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "superset.newTerminal",
                    "when": "view == superset.terminals",
                    "group": "navigation"
                },
                {
                    "command": "superset.newGroup",
                    "when": "view == superset.terminals",
                    "group": "navigation"
                },
                {
                    "command": "superset.mdnsRefresh",
                    "when": "view == superset.mdns",
                    "group": "navigation"
                },
                {
                    "command": "superset.topologyScan",
                    "when": "view == superset.topology",
                    "group": "navigation"
                },
                {
                    "command": "superset.todoViewSec",
                    "when": "view == superset.todo && superset.todo.viewType == 'section'",
                    "group": "navigation@0"
                },
                {
                    "command": "superset.todoViewPX",
                    "when": "view == superset.todo && superset.todo.viewType == 'priority'",
                    "group": "navigation@0"
                },
                {
                    "command": "superset.todoViewFile",
                    "when": "view == superset.todo && superset.todo.viewType == 'file'",
                    "group": "navigation@0"
                },
                {
                    "command": "superset.todoNew",
                    "when": "view == superset.todo",
                    "group": "navigation@1"
                },
                {
                    "command": "superset.todoFilterP0",
                    "when": "view == superset.todo && superset.todo.filterP0 != true",
                    "group": "navigation@2"
                },
                {
                    "command": "superset.todoFilterP0On",
                    "when": "view == superset.todo && superset.todo.filterP0 == true",
                    "group": "navigation@2"
                },
                {
                    "command": "superset.todoFilterP1",
                    "when": "view == superset.todo && superset.todo.filterP1 != true",
                    "group": "navigation@3"
                },
                {
                    "command": "superset.todoFilterP1On",
                    "when": "view == superset.todo && superset.todo.filterP1 == true",
                    "group": "navigation@3"
                },
                {
                    "command": "superset.todoFilterP2",
                    "when": "view == superset.todo && superset.todo.filterP2 != true",
                    "group": "navigation@4"
                },
                {
                    "command": "superset.todoFilterP2On",
                    "when": "view == superset.todo && superset.todo.filterP2 == true",
                    "group": "navigation@4"
                },
                {
                    "command": "superset.todoFilterHideCompleted",
                    "when": "view == superset.todo && superset.todo.filtering != true",
                    "group": "navigation@5"
                },
                {
                    "command": "superset.todoFilterShowAll",
                    "when": "view == superset.todo && superset.todo.filtering == true",
                    "group": "navigation@5"
                },
                {
                    "command": "superset.todoOpen",
                    "when": "view == superset.todo",
                    "group": "navigation@6"
                },
                {
                    "command": "superset.projectsTodoNew",
                    "when": "view == superset.projectsTodo",
                    "group": "navigation@1"
                },
                {
                    "command": "superset.projectsTodoFilterP0",
                    "when": "view == superset.projectsTodo && superset.projectsTodo.filterP0 != true",
                    "group": "navigation@2"
                },
                {
                    "command": "superset.projectsTodoFilterP0On",
                    "when": "view == superset.projectsTodo && superset.projectsTodo.filterP0 == true",
                    "group": "navigation@2"
                },
                {
                    "command": "superset.projectsTodoFilterP1",
                    "when": "view == superset.projectsTodo && superset.projectsTodo.filterP1 != true",
                    "group": "navigation@3"
                },
                {
                    "command": "superset.projectsTodoFilterP1On",
                    "when": "view == superset.projectsTodo && superset.projectsTodo.filterP1 == true",
                    "group": "navigation@3"
                },
                {
                    "command": "superset.projectsTodoFilterP2",
                    "when": "view == superset.projectsTodo && superset.projectsTodo.filterP2 != true",
                    "group": "navigation@4"
                },
                {
                    "command": "superset.projectsTodoFilterP2On",
                    "when": "view == superset.projectsTodo && superset.projectsTodo.filterP2 == true",
                    "group": "navigation@4"
                },
                {
                    "command": "superset.projectsTodoFilterHideCompleted",
                    "when": "view == superset.projectsTodo && superset.projectsTodo.filtering != true",
                    "group": "navigation@5"
                },
                {
                    "command": "superset.projectsTodoFilterShowAll",
                    "when": "view == superset.projectsTodo && superset.projectsTodo.filtering == true",
                    "group": "navigation@5"
                },
                {
                    "command": "superset.projectsTodoOpen",
                    "when": "view == superset.projectsTodo",
                    "group": "navigation@6"
                }
            ],
            "view/item/context": [
                {
                    "command": "superset.delete",
                    "when": "viewItem == terminal",
                    "group": "inline"
                },
                {
                    "command": "superset.focus",
                    "when": "viewItem == terminal",
                    "group": "1_focus"
                },
                {
                    "command": "superset.delete",
                    "when": "viewItem == terminal",
                    "group": "1_focus"
                },
                {
                    "command": "superset.copyName",
                    "when": "viewItem == terminal",
                    "group": "5_copy"
                },
                {
                    "command": "superset.rename",
                    "when": "viewItem == terminal",
                    "group": "2_rename"
                },
                {
                    "command": "superset.renameGroup",
                    "when": "viewItem == group",
                    "group": "1_group"
                },
                {
                    "command": "superset.setGroupColor",
                    "when": "viewItem == group",
                    "group": "1_group"
                },
                {
                    "command": "superset.deleteGroup",
                    "when": "viewItem == group",
                    "group": "9_group"
                },
                {
                    "command": "superset.mdnsCopy",
                    "when": "viewItem == mdnsService",
                    "group": "1_focus"
                },
                {
                    "command": "superset.mdnsShowDetail",
                    "when": "viewItem == mdnsService",
                    "group": "1_focus"
                },
                {
                    "command": "superset.mdnsConnect",
                    "when": "viewItem == mdnsService",
                    "group": "1_focus"
                },
                {
                    "command": "superset.mdnsCopyDetail",
                    "when": "viewItem == mdnsDetail",
                    "group": "1_focus"
                },
                {
                    "command": "superset.todoCopy",
                    "when": "viewItem == todoCheckbox || viewItem == todoCheckboxWithLink || viewItem == todoList || viewItem == todoListWithLink || viewItem == todoSection || viewItem == todoSectionArchivable || viewItem == todoSectionArchived || viewItem == todoCheckboxArchived || viewItem == todoCheckboxWithLinkArchived || viewItem == todoListArchived || viewItem == todoListWithLinkArchived || viewItem == todoPlan",
                    "group": "1_copy"
                },
                {
                    "command": "superset.todoRename",
                    "when": "viewItem == todoCheckbox || viewItem == todoCheckboxWithLink || viewItem == todoList || viewItem == todoListWithLink || viewItem == todoCheckboxArchived || viewItem == todoCheckboxWithLinkArchived || viewItem == todoListArchived || viewItem == todoListWithLinkArchived",
                    "group": "2_edit@1"
                },
                {
                    "command": "superset.todoChangePriority",
                    "when": "viewItem == todoCheckbox || viewItem == todoCheckboxWithLink || viewItem == todoCheckboxArchived || viewItem == todoCheckboxWithLinkArchived",
                    "group": "2_edit@2"
                },
                {
                    "command": "superset.todoChangeSection",
                    "when": "viewItem == todoCheckbox || viewItem == todoCheckboxWithLink || viewItem == todoList || viewItem == todoListWithLink || viewItem == todoCheckboxArchived || viewItem == todoCheckboxWithLinkArchived || viewItem == todoListArchived || viewItem == todoListWithLinkArchived",
                    "group": "2_edit@3"
                },
                {
                    "command": "superset.todoArchive",
                    "when": "viewItem == todoCheckbox || viewItem == todoCheckboxWithLink || viewItem == todoList || viewItem == todoListWithLink",
                    "group": "2_edit@4"
                },
                {
                    "command": "superset.todoRollback",
                    "when": "viewItem == todoCheckboxArchived || viewItem == todoCheckboxWithLinkArchived || viewItem == todoListArchived || viewItem == todoListWithLinkArchived",
                    "group": "2_edit@4"
                },
                {
                    "command": "superset.todoArchiveSection",
                    "when": "viewItem == todoSectionArchivable",
                    "group": "2_edit@1"
                },
                {
                    "command": "superset.todoUnarchiveSection",
                    "when": "viewItem == todoSectionArchived",
                    "group": "2_edit@1"
                },
                {
                    "command": "superset.todoNew",
                    "when": "viewItem == todoSection || viewItem == todoSectionArchivable || viewItem == todoSectionArchived",
                    "group": "inline"
                },
                {
                    "command": "superset.todoOpen",
                    "when": "viewItem == todoSection || viewItem == todoSectionArchivable || viewItem == todoSectionArchived",
                    "group": "inline"
                },
                {
                    "command": "superset.todoOpenLink",
                    "when": "viewItem == todoCheckboxWithLink || viewItem == todoListWithLink || viewItem == todoCheckboxWithLinkArchived || viewItem == todoListWithLinkArchived || viewItem == todoPlan",
                    "group": "inline"
                },
                {
                    "command": "superset.todoBacklogPlan",
                    "when": "viewItem == todoPlan",
                    "group": "2_edit@1"
                },
                {
                    "command": "superset.todoArchivePlan",
                    "when": "viewItem == todoPlan",
                    "group": "2_edit@2"
                },
                {
                    "command": "superset.todoDeletePlan",
                    "when": "viewItem == todoPlan",
                    "group": "3_delete"
                },
                {
                    "command": "superset.todoDeleteSection",
                    "when": "(viewItem == todoSection || viewItem == todoSectionArchivable || viewItem == todoSectionArchived) && superset.todo.viewType == 'section'",
                    "group": "3_delete"
                },
                {
                    "command": "superset.todoDelete",
                    "when": "viewItem == todoCheckbox || viewItem == todoCheckboxWithLink || viewItem == todoList || viewItem == todoListWithLink || viewItem == todoCheckboxArchived || viewItem == todoCheckboxWithLinkArchived || viewItem == todoListArchived || viewItem == todoListWithLinkArchived",
                    "group": "3_delete"
                },
                {
                    "command": "superset.projectsTodoCopy",
                    "when": "viewItem == projectsTodoCheckbox || viewItem == projectsTodoCheckboxWithLink || viewItem == projectsTodoSection || viewItem == projectsTodoSectionArchivable || viewItem == projectsTodoSectionArchived || viewItem == projectsTodoCheckboxArchived || viewItem == projectsTodoCheckboxWithLinkArchived || viewItem == projectsTodoList || viewItem == projectsTodoListWithLink || viewItem == projectsTodoListArchived || viewItem == projectsTodoListWithLinkArchived || viewItem == projectsTodoProject || viewItem == projectsTodoPlan",
                    "group": "1_copy"
                },
                {
                    "command": "superset.projectsTodoRename",
                    "when": "viewItem == projectsTodoCheckbox || viewItem == projectsTodoCheckboxWithLink || viewItem == projectsTodoList || viewItem == projectsTodoListWithLink || viewItem == projectsTodoCheckboxArchived || viewItem == projectsTodoCheckboxWithLinkArchived || viewItem == projectsTodoListArchived || viewItem == projectsTodoListWithLinkArchived",
                    "group": "2_edit@1"
                },
                {
                    "command": "superset.projectsTodoChangePriority",
                    "when": "viewItem == projectsTodoCheckbox || viewItem == projectsTodoCheckboxWithLink || viewItem == projectsTodoCheckboxArchived || viewItem == projectsTodoCheckboxWithLinkArchived",
                    "group": "2_edit@2"
                },
                {
                    "command": "superset.projectsTodoChangeSection",
                    "when": "viewItem == projectsTodoCheckbox || viewItem == projectsTodoCheckboxWithLink || viewItem == projectsTodoList || viewItem == projectsTodoListWithLink || viewItem == projectsTodoCheckboxArchived || viewItem == projectsTodoCheckboxWithLinkArchived || viewItem == projectsTodoListArchived || viewItem == projectsTodoListWithLinkArchived",
                    "group": "2_edit@3"
                },
                {
                    "command": "superset.projectsTodoArchive",
                    "when": "viewItem == projectsTodoCheckbox || viewItem == projectsTodoCheckboxWithLink || viewItem == projectsTodoList || viewItem == projectsTodoListWithLink",
                    "group": "2_edit@4"
                },
                {
                    "command": "superset.projectsTodoRollback",
                    "when": "viewItem == projectsTodoCheckboxArchived || viewItem == projectsTodoCheckboxWithLinkArchived || viewItem == projectsTodoListArchived || viewItem == projectsTodoListWithLinkArchived",
                    "group": "2_edit@4"
                },
                {
                    "command": "superset.projectsTodoArchiveSection",
                    "when": "viewItem == projectsTodoSectionArchivable",
                    "group": "2_edit@1"
                },
                {
                    "command": "superset.projectsTodoUnarchiveSection",
                    "when": "viewItem == projectsTodoSectionArchived",
                    "group": "2_edit@1"
                },
                {
                    "command": "superset.projectsTodoNew",
                    "when": "viewItem == projectsTodoSection || viewItem == projectsTodoSectionArchivable || viewItem == projectsTodoSectionArchived || viewItem == projectsTodoProject",
                    "group": "inline"
                },
                {
                    "command": "superset.projectsTodoOpen",
                    "when": "viewItem == projectsTodoSection || viewItem == projectsTodoSectionArchivable || viewItem == projectsTodoSectionArchived || viewItem == projectsTodoProject",
                    "group": "inline"
                },
                {
                    "command": "superset.projectsTodoOpenLink",
                    "when": "viewItem == projectsTodoCheckboxWithLink || viewItem == projectsTodoListWithLink || viewItem == projectsTodoCheckboxWithLinkArchived || viewItem == projectsTodoListWithLinkArchived || viewItem == projectsTodoPlan",
                    "group": "inline"
                },
                {
                    "command": "superset.projectsTodoBacklogPlan",
                    "when": "viewItem == projectsTodoPlan",
                    "group": "2_edit@1"
                },
                {
                    "command": "superset.projectsTodoArchivePlan",
                    "when": "viewItem == projectsTodoPlan",
                    "group": "2_edit@2"
                },
                {
                    "command": "superset.projectsTodoDeletePlan",
                    "when": "viewItem == projectsTodoPlan",
                    "group": "3_delete"
                },
                {
                    "command": "superset.openProject",
                    "when": "viewItem == projectsTodoPlan",
                    "group": "inline"
                },
                {
                    "command": "superset.projectsTodoDeleteSection",
                    "when": "viewItem == projectsTodoSection || viewItem == projectsTodoSectionArchivable || viewItem == projectsTodoSectionArchived",
                    "group": "3_delete"
                },
                {
                    "command": "superset.projectsTodoDelete",
                    "when": "viewItem == projectsTodoCheckbox || viewItem == projectsTodoCheckboxWithLink || viewItem == projectsTodoList || viewItem == projectsTodoListWithLink || viewItem == projectsTodoCheckboxArchived || viewItem == projectsTodoCheckboxWithLinkArchived || viewItem == projectsTodoListArchived || viewItem == projectsTodoListWithLinkArchived",
                    "group": "3_delete"
                },
                {
                    "command": "superset.openProject",
                    "when": "viewItem == projectsTodoProject",
                    "group": "inline"
                }
            ]
        },
        "scm/historyItem/context": [
            {
                "command": "superset.gitResetSoft",
                "group": "modification@1"
            },
            {
                "command": "superset.gitResetHard",
                "group": "modification@2"
            }
        ],
        "scm/graph/context": [
            {
                "command": "superset.gitResetSoft",
                "group": "modification@1"
            },
            {
                "command": "superset.gitResetHard",
                "group": "modification@2"
            }
        ],
        "keybindings": [
            {
                "command": "superset.rename",
                "key": "F2",
                "when": "focusedView == superset.terminals && !inputFocus"
            },
            {
                "command": "superset.todoRename",
                "key": "F2",
                "when": "focusedView == superset.todo && !inputFocus"
            },
            {
                "command": "superset.projectsTodoRename",
                "key": "F2",
                "when": "focusedView == superset.projectsTodo && !inputFocus"
            },
            {
                "command": "superset.newTerminal",
                "key": "ctrl+shift+`",
                "mac": "ctrl+shift+`",
                "when": "terminalFocus || !terminalFocus"
            },
            {
                "command": "superset.jumpToTerminal",
                "key": "ctrl+alt+t",
                "mac": "ctrl+alt+t"
            }
        ]
    },
    "scripts": {
        "clean": "rm -f *.vsix",
        "build": "npm run clean && npm install && tsc && npx @vscode/vsce package && bash scripts/verify-vsix.sh",
        "watch": "tsc --watch",
        "package": "vsce package",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@types/multicast-dns": "^7.2.4",
        "@types/node": "^26.0.0",
        "@types/vscode": "~1.93.0",
        "typescript": "^5.4.0",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
        "multicast-dns": "^7.2.5"
    }
}

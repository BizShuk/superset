{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$tsc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "echo": true,
                "clear": true,
                "close": true
            },
            "label": "npm: build"
        },
        {
            "label": "Install Extension",
            "type": "shell",
            "command": "agy-ide --install-extension *.vsix --force",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true,
                "clear": true
            }
        }
    ]
}

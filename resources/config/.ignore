.pids
*.pid
*.seed
*.pid.lock

# Heap / core dumps

heapdump.*
*.core
core.*

# ── I. Secrets / Env / Local config ─────────────────────────────────────────

.env
.env.*
!.env.example
.env.tmp
.env.local
.env.*.local

# SSH keys (private keys, configs, known_hosts, agent sockets)

id_rsa
id_rsa.*
id_dsa
id_dsa.*
id_ecdsa
id_ecdsa.*
id_ed25519
id_ed25519.*
id_xmss
id_xmss.*
*.pub
!*.ignore.pub
known_hosts
authorized_keys
ssh_config
.ssh/
.ssh/known_hosts
.ssh/authorized_keys
*.ppk
ssh-agent-sock
agent.sock

# GPG / PGP

*.asc
*.gpg
*.pgp
secring.gpg
pubring.gpg
.gnupg/

# SSL / TLS

*.pem
*.key
*.crt
*.cer
*.csr
*.p12
*.pfx
keystore.jks
truststore.jks

secrets/
.secrets/
config/local.json
config/local.yaml
config/local.yml
config/local.toml

# ── J. Lockfile noise (node_modules 內大量 json,通常不需索引) ────────────────

# package-lock.json / yarn.lock / pnpm-lock.yaml 在多數專案要進版控

# 這裡只忽略常見的"次要"或備份

*.lock.bak
package-lock.json.bak
yarn.lock.bak


coverage/
.nyc_output/
*.lcov

# Jest / Vitest

.jest-cache/

# Framework

.nuxt/
.nest/
.tmp/

# ── D. Go ────────────────────────────────────────────────────────────────────

# Binaries

*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go workspace

go.work
go.work.sum

# Coverage

coverage.txt
coverage.html
cover.out
cover.html

# Dependency dirs

vendor/

# Cobra / stringer generated

__debug_bin
*_string.go
*_stringer.go

